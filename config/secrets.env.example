# AlmaPay secrets example. Copy to /var/lib/almapay/secrets.env with mode 0600.
# Never commit real values. AlmaPay parses this file as strict data; it never sources it.
# Pass secrets via this file or stdin — never as process arguments.

POSTGRES_USER=postgres
POSTGRES_DB=postgres
POSTGRES_PASSWORD=replace-with-long-random-value

# Optional least-privilege verification credentials. Required only by
# almapay verify --production after production verification is implemented.
# ALMAPAY_VERIFY_API_KEY=
# ALMAPAY_VERIFY_STORE_ID=
# ALMAPAY_VERIFY_WEBHOOK_URL=

# Optional plugin provider credentials (store-scoped in BTCPay UI preferred):
# STRIPE_TEST_SECRET_KEY=
# STRIPE_LIVE_SECRET_KEY=
# BOLTZ_API_KEY=
